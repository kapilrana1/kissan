<%- include('../partials/header') %>

<div class="page-header">
  <h1><%= farmer ? 'Edit Farmer Account' : 'Add New Farmer' %></h1>
</div>

<div class="card">
  <form method="POST" action="<%= farmer ? `/farmers/${farmer.id}?_method=PUT` : '/farmers' %>">
    <div class="form-row">
      <div class="form-group">
        <label>Farmer's Name *</label>
        <input type="text" name="name" value="<%= farmer ? farmer.name : '' %>" required>
      </div>
      <div class="form-group">
        <label>Mobile Number *</label>
        <input type="text" name="mobile" value="<%= farmer ? farmer.mobile : '' %>" required>
      </div>
    </div>

    <div class="form-group">
      <label>Address</label>
      <input type="text" name="address" value="<%= farmer ? farmer.address : '' %>">
    </div>

    <div class="actions-row">
      <button type="submit" class="btn"><%= farmer ? 'Update' : 'Create Account' %></button>
      <a href="/farmers" class="btn secondary">Cancel</a>
    </div>
  </form>

  <% if (farmer) { %>
    <hr style="margin:24px 0; border:none; border-top:1px solid var(--border)">
    <form method="POST" action="/farmers/<%= farmer.id %>?_method=DELETE" data-confirm="Are you sure you want to delete this farmer's account? This will also delete all their wheat entries.">
      <button type="submit" class="btn danger">Delete Farmer Account</button>
    </form>
  <% } %>
</div>

<%- include('../partials/footer') %>
